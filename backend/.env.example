# --- Runtime ---
NODE_ENV=development
# Note: macOS uses :5000 for AirPlay Receiver. Use 5001 (or anything else) to avoid clashes.
PORT=5001

# --- Database ---
# A standard MongoDB connection string. Both Mongoose and the Better Auth
# MongoDB adapter share this database so sessions issued by the Next.js app
# are honoured by the Express API.
MONGODB_URI=mongodb://127.0.0.1:27017/smart_earning_pro

# --- Better Auth ---
# Must match the same value used in the Next.js frontend so the shared
# session table can be read on both sides.
BETTER_AUTH_SECRET=replace-with-a-long-random-string
# Public URL where Better Auth is hosted (the Next.js app).
BETTER_AUTH_URL=http://localhost:3000

# Comma separated list of EXACT origins allowed to call the API.
# NOTE: src/app.ts ALSO allows `*.vercel.app`, `*.onrender.com` and any
# `localhost:<port>` via regex — only add a host here if it doesn't
# match one of those patterns (e.g. a custom domain).
TRUSTED_ORIGINS=http://localhost:3000,https://lead-generation-client-project.onrender.com

# --- Cloudinary (media uploads) ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_FOLDER=smart-earning-pro
